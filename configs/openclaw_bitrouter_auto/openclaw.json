{
  "models": {
    "providers": {
      "bitrouter": {
        "baseUrl": "http://localhost:8787",
        "apiKey": "bench",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "bitrouter/auto",
            "name": "BitRouter Auto",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": {
              "input": 5.0,
              "output": 25.0,
              "cacheRead": 0.5,
              "cacheWrite": 6.25
            },
            "contextWindow": 1000000,
            "maxTokens": 128000
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "bitrouter:bitrouter/auto"
      },
      "timeoutSeconds": 600
    }
  }
}
